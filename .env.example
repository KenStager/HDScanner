# Database
DATABASE_URL=sqlite+aiosqlite:///./dev.db
# Use postgresql+asyncpg://user:pass@localhost/hd_monitor for prod

# API
API_ENDPOINT=https://apionline.homedepot.com/federation-gateway/graphql

# Crawl settings
STORES=2619,8425
BRANDS=Milwaukee
PRODUCT_LINE_FILTERS=M12,M18
TOOLS_NAV_PARAM=N-5yc1vZc1xy
CLEARANCE_TOKEN=1z11adf
MAX_CONCURRENCY=3
RATE_LIMIT_RPS=1.0
JITTER_MIN_MS=200
JITTER_MAX_MS=800
MAX_PAGES=10
PAGE_SIZE=24

# Pipeline
STAGE_DELAY_SECONDS=5

# Safety
CIRCUIT_BREAKER_FAILURE_THRESHOLD=10
CIRCUIT_BREAKER_WINDOW_SECONDS=60
DRIFT_FAILURE_THRESHOLD_PCT=50

# Diff
DIFF_GAP_THRESHOLD_HOURS=48
DIFF_STALE_GAP_HOURS=168

# Maintenance
SNAPSHOT_RETENTION_DAYS=90

# Storage
STORE_RAW_JSON=true
RAW_JSON_DIR=./raw_responses

# Dashboard
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8080
DASHBOARD_TITLE=HD Clearance Monitor
DASHBOARD_REFRESH_SECONDS=300
DASHBOARD_DARK_MODE=true

# Optional notifiers (v1: unused, leave blank)
DISCORD_WEBHOOK_URL=
EMAIL_SMTP_HOST=
